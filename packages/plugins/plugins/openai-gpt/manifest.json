{
  "$schema": "../../manifest-schema.json",
  "id": "openai-gpt",
  "name": "OpenAI GPT",
  "version": "1.0",
  "kind": "cloud",
  "capabilities": ["llm"],
  "flavor": "openai-chat",
  "repository": "https://openai.com",
  "readmeUrl": "https://platform.openai.com/docs/guides/text-generation",
  "license": "proprietary",
  "description": "OpenAI chat-completion / responses APIs. Pay-per-token. Alternative LLM for editorial agents — useful when you want a second opinion or hit Claude quota limits.",
  "hardware": {
    "any": { "support": "best", "accel": "any" }
  },
  "defaults": {
    "baseUrl": "https://api.openai.com",
    "model": "gpt-4o"
  },
  "endpoint": {
    "baseUrl": "https://api.openai.com",
    "apiVersion": "v1",
    "docsUrl": "https://platform.openai.com/docs/api-reference/chat"
  },
  "authentication": {
    "type": "bearer",
    "header": "Authorization",
    "apiKeyEnvVar": "OPENAI_API_KEY",
    "signupUrl": "https://platform.openai.com/signup",
    "consoleUrl": "https://platform.openai.com/api-keys"
  },
  "pricing": {
    "url": "https://openai.com/api/pricing",
    "model": "pay-per-token",
    "freeTier": "Free trial credits on new accounts."
  },
  "terms": "https://openai.com/policies/terms-of-use",
  "probe": {
    "path": "/v1/models",
    "method": "GET",
    "expectedStatus": 200
  }
}
