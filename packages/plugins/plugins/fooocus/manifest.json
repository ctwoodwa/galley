{
  "$schema": "../../manifest-schema.json",
  "id": "fooocus",
  "name": "Fooocus",
  "version": "1.0",
  "kind": "local",
  "capabilities": ["image"],
  "flavor": "fooocus",
  "repository": "https://github.com/lllyasviel/Fooocus",
  "readmeUrl": "https://github.com/lllyasviel/Fooocus#readme",
  "license": "GPL-3.0",
  "description": "Simpler 'Midjourney-style' wrapper around SDXL. Lower ceiling than ComfyUI but much easier first-image experience. Good fit for authors who want cover art without learning node graphs.",
  "hardware": {
    "macos-arm64":           { "support": "ok",   "accel": "mps" },
    "windows-x86_64-nvidia": { "support": "best", "accel": "cuda" },
    "linux-x86_64-nvidia":   { "support": "best", "accel": "cuda" }
  },
  "defaults": {
    "port": 7865,
    "baseUrl": "http://localhost:7865"
  },
  "install": {
    "prerequisites": ["python>=3.10", "git", "cuda-toolkit>=12.0 (windows/linux)"],
    "installDirDefault": "${HOME}/galley-tools/Fooocus",
    "steps": {
      "macos":   ["git clone https://github.com/lllyasviel/Fooocus.git $INSTALL_DIR", "cd $INSTALL_DIR && python3 -m venv venv && source venv/bin/activate && pip install -r requirements_versions.txt"],
      "linux":   ["git clone https://github.com/lllyasviel/Fooocus.git $INSTALL_DIR", "cd $INSTALL_DIR && python3 -m venv venv && source venv/bin/activate && pip install -r requirements_versions.txt"],
      "windows": ["git clone https://github.com/lllyasviel/Fooocus.git $INSTALL_DIR", "cd $INSTALL_DIR; python -m venv venv; .\\venv\\Scripts\\activate; pip install -r requirements_versions.txt"]
    }
  },
  "launch": {
    "macos":   "cd {install_dir} && source venv/bin/activate && python entry_with_update.py --port {port} --listen",
    "linux":   "cd {install_dir} && source venv/bin/activate && python entry_with_update.py --port {port} --listen",
    "windows": "cd {install_dir}; .\\venv\\Scripts\\activate; python entry_with_update.py --port {port} --listen"
  },
  "health": {
    "path": "/",
    "expectedStatus": 200
  }
}
