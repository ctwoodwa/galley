# Defaults for apps/web Vite build. Copy to .env.local and fill in.
# .env.local is gitignored; never commit your API key.

# Inference API base URL (defaults to http://desktop-umt08rn:8881 if unset)
# VITE_GALLEY_API_BASE_URL=http://desktop-umt08rn:8881

# Inference API Bearer token (required for /api/v1/audio/voices and other
# protected endpoints). Get this from the server operator.
# VITE_GALLEY_API_KEY=
