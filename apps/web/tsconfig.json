{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "allowJs": true,
    "checkJs": false,
    "strict": false,
    "noEmit": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "paths": {
      "@galley/types": ["../../packages/types/src/index"],
      "@galley/ui": ["../../packages/ui/src/index"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
