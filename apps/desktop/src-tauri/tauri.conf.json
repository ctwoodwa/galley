{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Galley",
  "version": "0.1.0",
  "identifier": "com.sunfishsoftware.galley",
  "build": {
    "beforeDevCommand": "pnpm --filter @galley/web dev",
    "beforeBuildCommand": "pnpm --filter @galley/web build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Galley",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "visible": true,
        "hiddenTitle": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "Editorial production platform — book publishing workflows.",
    "longDescription": "Galley is a local-first, self-hosted editorial production platform for book publishing. It bundles a tray-supervised book server, a prose-telemetry pipeline, and the Galley web UI in one installable desktop app.",
    "copyright": "© 2026 Sunfish Software",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": []
  }
}
